# Required server env
# Local dev origin and database.
CORS_ORIGIN=http://localhost:3001
DATABASE_URL=postgresql://postgres:password@localhost:5432/harvverse-copernicus-hackathon

# Required Clerk auth env
# Redirects are configured in code:
# - sign in -> /dashboard
# - sign up -> /onboarding
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Optional investment contract configuration
# For the hackathon demo, local Hardhat contracts are enough.
NEXT_PUBLIC_USE_LOCAL_CONTRACTS=true
NEXT_PUBLIC_HARDHAT_CHAIN_ID=31337
NEXT_PUBLIC_USDC_ADDRESS=
NEXT_PUBLIC_LOT_ADDRESS=
NEXT_PUBLIC_PARTNERSHIP_ADDRESS=

# Optional local contract override for scripts.
HARVVERSE_LOT_ADDRESS=

# Copernicus provider credentials
# Fixture scoring works without these.
# Live Sentinel-2/Sentinel-1/DEM scoring must fail unless these two are set.
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=

# Reserved for direct CDS ERA5. Current climate development path can still use
# Open-Meteo Archive as an ERA5-backed provider until CDS is wired.
CDS_API_KEY=

# Optional Sheyla/n8n WhatsApp workflow webhook.
# If set, POST /api/sentinel/alerts validates the event and forwards it there.
N8N_WEBHOOK_URL=
